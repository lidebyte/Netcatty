{
  "$schema": "../../../packages/plugin-contract/schema/plugin-contract.schema.json",
  "manifestVersion": 1,
  "id": "com.netcatty.hello",
  "name": "hello-netcatty",
  "displayName": {
    "en": "Hello Netcatty",
    "zh-CN": "你好，Netcatty"
  },
  "description": "Minimal plugin contract and SDK example.",
  "version": "0.1.0",
  "publisher": "netcatty",
  "license": "GPL-3.0-or-later",
  "engines": {
    "netcatty": ">=0.0.0",
    "api": "0.1.0-internal"
  },
  "main": {
    "browser": "dist/index.js"
  },
  "activationEvents": [
    "onCommand:hello.sayHello"
  ],
  "permissions": {
    "required": [
      "commands",
      "settings"
    ],
    "optional": []
  },
  "contributes": {
    "settings": [
      {
        "id": "hello.greeting",
        "label": "Greeting",
        "description": "Text used by the example command.",
        "control": "text",
        "scope": "application",
        "default": "Hello from Netcatty"
      }
    ],
    "commands": [
      {
        "id": "hello.sayHello",
        "title": "Say Hello",
        "category": "Examples"
      }
    ],
    "menus": [
      {
        "command": "hello.sayHello",
        "location": "commandPalette",
        "group": "examples",
        "order": 10
      }
    ]
  }
}
